{
  "name": "@ohzw/worktree-command-tui",
  "version": "0.1.5",
  "description": "A TUI for managing git worktrees",
  "private": false,
  "type": "module",
  "license": "MIT",
  "author": "ohzw",
  "homepage": "https://github.com/ohzw/worktree-command-tui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ohzw/worktree-command-tui.git"
  },
  "bugs": {
    "url": "https://github.com/ohzw/worktree-command-tui/issues"
  },
  "keywords": [
    "cli",
    "git",
    "worktree",
    "tui",
    "terminal"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "init": "tsx src/main.tsx init",
    "start": "tsx src/main.tsx",
    "start:built": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "wctui": "./dist/main.js",
    "worktree-command-tui": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^7.0.4",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
